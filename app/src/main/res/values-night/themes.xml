<resources xmlns:tools="http://schemas.apple.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CapstoneAndroidExpert" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Theme backgrounds and surfaces (Dark) -->
        <item name="android:windowBackground">@color/background_color_dark</item>
        <item name="colorSurface">@color/surface_color_dark</item>
        <item name="colorOnBackground">@color/onBackgroundDark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>

        <!-- Status bar styling -->
        <item name="android:statusBarColor">@color/background_color_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>